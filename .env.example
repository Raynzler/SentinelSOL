# --- SentinelSOL Deployment Mode ---

# LOCAL MODE (Default): Runs alongside the validator on the same machine.
RPC_URL=http://localhost:8899

# OOB MODE (True Out-of-Band): Runs on an isolated VPS.
# Replace with your validator's exposed IP or secure WireGuard tunnel.
# RPC_URL=http://<VALIDATOR_IP>:8899

# Telegram Alerting Configuration
TELEGRAM_BOT_TOKEN=your_botfather_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here

# Grafana Security
GRAFANA_ADMIN_PASSWORD=colosseum
